# ==========================================
# GESTIONAR2 - Variables de Entorno
# Copiar a .env y completar los valores
# ==========================================

# --- App ---
NODE_ENV=production

# --- Base de Datos ---
POSTGRES_USER=gestionar2
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=gestionar2
DATABASE_URL=postgresql://gestionar2:CAMBIAR_PASSWORD_SEGURO@postgres:5432/gestionar2

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD
REDIS_URL=redis://:CAMBIAR_REDIS_PASSWORD@redis:6379

# --- JWT ---
# Generá con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_JWT_SECRET_MUY_LARGO
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CAMBIAR_JWT_REFRESH_SECRET_MUY_LARGO
JWT_REFRESH_EXPIRES_IN=30d

# --- Telegram Bot ---
# Obtené el token en @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# URL pública de tu servidor (necesario para webhooks)
# Ejemplo: https://tudominio.com
TELEGRAM_WEBHOOK_URL=https://api.tudominio.com

# --- IA Services (Gratuitas) ---
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
REPLICATE_API_KEY=
OPENROUTER_API_KEY=
DEEPINFERA_API_KEY=
FIREWORKS_API_KEY=
ANYSCALE_API_KEY=

# --- IA Services (Pagos - Respaldo para extracción de facturas) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- AWS (para Textract opcional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# --- URLs ---
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# --- Para producción con dominio propio ---
# NEXT_PUBLIC_API_URL=https://api.tudominio.com
# FRONTEND_URL=https://tudominio.com
# TELEGRAM_WEBHOOK_URL=https://api.tudominio.com



QUIERO TENER DOS MODOS (PERSONAL - EMPRESARIAL) DONDE CADA MODO TIENE SUS SECCIONES CORRESPONDIENTES, LOS DATOS NO SE TIENEN QUE MEZCLAR.
MODO PERSONAL
-DASHBOARD
-INGRESOS
-GASTOS
-RESUMEN
-MOVIMIENTOS
-CATEGORIAS
-REPORTES
-CONFIGURACION
-DIVIDIR (Herramienta adicional para hacer divisiones. por ejemplo, se sube los que gasto cada uno para hacer un asado. teniendo en cuenta que uno compra la carne otro compra el pan y otro las bebidas. se sube lo que gasto cada uno, la cantidad de personas y se divide cuanto le debe cada uno a cada uno )

MODO EMPRESARIAL
-DASHBOARD
-SUBIR FACTURAS
-CLIENTES
-FACTURAS
-INGRESOS
-GASTOS
-RESUMEN
-MOVIMIENTOS
-CATEGORIAS
-REPORTES


